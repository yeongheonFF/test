<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <title>시현이와 영헌이의 과일가게</title>
    <style>
        body {
            font-family: sans-serif;
            line-height: 1.6;
            padding: 20px;
            background-color: #a3d6da;
        }

        header {
            text-align: center;
        }

        nav {
            margin-top: 20px;
            margin-bottom: 250px;
        }

        a {
            font-size: 24px;
            font-weight: bold;
            color: #333;
            text-decoration: none;
            text-align: right;
        }

        .balance {
            margin-top: 10px;
            font-size: 18px;
            text-align: right;
        }

        nav button {
            cursor: pointer;
            background: #6248be;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 3px;
        }

        nav button:hover {
            background: #2ecc71;
        }

        .product-list {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 0 auto 30px;
            flex-wrap: wrap;
        }

        .product-card {
            background: white;
            padding: 15px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            width: 150px;
            text-align: center;
        }

        .cart {
            background: #fff;
            padding: 20px;
            border-radius: 8px;
            border: 2px solid #333;
            max-width: 200px;
            margin: 0 auto;
        }

        .cart-title {
            position: relative;
            display: inline-block;
        }

        .cart-alert {
            position: absolute;
            top: -14px;
            left: 8px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #ff3b30;
            color: #fff;
            font-size: 12px;
            font-weight: bold;
            display: none;
            align-items: center;
            justify-content: center;
            line-height: 1;
        }

        button {
            cursor: pointer;
            background: #27ae60;
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 3px;
        }

        button:hover {
            background: #2ecc71;
        }
    </style>
</head>

<body>
    <header>
        <a href="test.html">시현이와 영헌이의 과일가게</a>
        <p class="balance"><strong>보유금액 : <span id="balance">10,000</span>원</strong></p>
        <nav>
            <button type="button">과일</button>
            <button type="button">채소</button>
        </nav>
    </header>

    <div class="product-list">
        <div class="product-card">
            <h3>🍎 사과</h3>
            <p>1,000원</p>
            <button onclick="addToCart('사과', 1000)">담기</button>
        </div>
        <div class="product-card">
            <h3>🍌 바나나</h3>
            <p>2,000원</p>
            <button onclick="addToCart('바나나', 2000)">담기</button>
        </div>
        <div class="product-card">
            <h3>🍊 오렌지</h3>
            <p>1,500원</p>
            <button onclick="addToCart('오렌지', 1500)">담기</button>
        </div>
        <div class="product-card">
            <h3>🍇 포도</h3>
            <p>3,000원</p>
            <button onclick="addToCart('포도', 3000)">담기</button>
        </div>

    </div>

    <div class="cart">
        <h2 class="cart-title"><span id="cart-alert" class="cart-alert">!</span>🛒 장바구니</h2>
        <ul id="cart-items">
        </ul>
        <p><strong>총 결제 금액: <span id="total-price">0</span>원</strong></p>
    </div>

    <script>
        let total = 0;
        let balance = 10000;
        const cartList = document.getElementById('cart-items');
        const totalPriceDisplay = document.getElementById('total-price');
        const balanceDisplay = document.getElementById('balance');
        const cartAlert = document.getElementById('cart-alert');

        function addToCart(name, price) {
            // 0. 보유금액 체크
            if (balance < price) {
                return alert("보유금액이 부족합니다!");
            }
            // 1. 장바구니 이모지 위에 빨간색 느낌표 표시
            cartAlert.style.display = 'flex';

            // 2. 총 금액 업데이트
            total += price;
            totalPriceDisplay.innerText = total.toLocaleString();

            // 3. 보유금액 업데이트
            balance -= price;
            balanceDisplay.innerText = balance.toLocaleString();
        }
    </script>

</body>

</html>
